{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(tree:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*credentials*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== MEMORIA PROGETTO (STATE.md) ===' && cat .claude/memory/STATE.md 2>/dev/null || echo 'Memoria non inizializzata: vedi SETUP.md'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "gitleaks protect --staged --no-banner 2>/dev/null || echo 'WARN: gitleaks non installato — installalo per il secret scanning'"
          }
        ]
      }
    ]
  }
}
