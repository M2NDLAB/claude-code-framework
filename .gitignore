# ============================================================================
# Framework base .gitignore — stack-agnostic.
# Add your OWN stack's artifacts below (see the section at the bottom).
# ============================================================================

# Environment & secrets — NEVER commit (rule 1)
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.jks
**/secrets/
.vault-token
vault-keys.json

# IDE / OS
.idea/
.vscode/
*.iml
.DS_Store

# Log
*.log

# Local Claude Code (personal settings, not shared)
.claude/settings.local.json

# (Optional) local config of the Obsidian vault, if you open .claude/ in Obsidian
.obsidian/

# ============================================================================
# [TO BE DEFINED AT SETUP] — build artifacts/dependencies of your stack.
# Uncomment/add what you need. Common examples:
# ----------------------------------------------------------------------------
# Node:    node_modules/  dist/  build/  .next/  out/  *.tsbuildinfo  coverage/
# Java:    target/  *.class  *.jar
# Python:  __pycache__/  *.pyc  .venv/  .pytest_cache/  .mypy_cache/
# Go:      /bin/  *.test
# Rust:    /target/
# ============================================================================
